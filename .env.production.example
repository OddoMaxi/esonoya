# ─────────────────────────────────────────────────────────────────────────────
# eSonoya — Production Environment Template
# Copy to .env.production, fill in real values, NEVER commit to git.
# ─────────────────────────────────────────────────────────────────────────────

APP_NAME=eSonoya
APP_ENV=production
APP_KEY=base64:GENERATE_WITH_php_artisan_key:generate
APP_DEBUG=false
APP_URL=https://api.esonoya.gov.gn
APP_TIMEZONE=Africa/Conakry
APP_LOCALE=fr

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=warning

# ─── Base de données ─────────────────────────────────────────────────────────
# In production the API connects through PgBouncer (connection pooling).
DB_CONNECTION=pgsql
DB_HOST=pgbouncer
DB_PORT=5432
DB_DATABASE=esonoya
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32_CHARS_MIN

# ─── Session & Cache ─────────────────────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.esonoya.gov.gn

CACHE_STORE=redis

# ─── Queue ───────────────────────────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
REDIS_PORT=6379

# ─── Mail ────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.gov.gn
MAIL_PORT=587
MAIL_USERNAME=noreply@esonoya.gov.gn
MAIL_PASSWORD=CHANGE_ME
MAIL_FROM_ADDRESS="noreply@esonoya.gov.gn"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Sanctum (CORS stateful) ─────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=esonoya.gov.gn,www.esonoya.gov.gn,admin.esonoya.gov.gn
SANCTUM_EXPIRATION=10080

# ─── CORS ────────────────────────────────────────────────────────────────────
FRONTEND_URL=https://esonoya.gov.gn
ADMIN_URL=https://admin.esonoya.gov.gn

# ─── SMS — InteractGroup ─────────────────────────────────────────────────────
SMS_PROVIDER=interactgroup
SMS_SENDER_ID=eSonoya
SMS_RETRY_ATTEMPTS=3
SMS_INTERACTGROUP_URL=http://sms.interactgroup.net/index.php
SMS_USERNAME=CHANGE_ME
SMS_TOKEN=CHANGE_ME

# ─── OTP ─────────────────────────────────────────────────────────────────────
OTP_LENGTH=6
OTP_EXPIRES_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RATE_LIMIT_MINUTES=1

# ─── QR Code ─────────────────────────────────────────────────────────────────
QR_SECRET_KEY=CHANGE_ME_MINIMUM_32_RANDOM_CHARS

# ─── Rappels RDV ─────────────────────────────────────────────────────────────
REMINDER_HOURS_BEFORE=24

# ─── Tokens ──────────────────────────────────────────────────────────────────
TOKEN_CITIZEN_DAYS=7
TOKEN_ADMIN_HOURS=8

# ─── Sécurité — mots de passe admin ─────────────────────────────────────────
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPER=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=true

# ─── Sécurité — Brute-force ──────────────────────────────────────────────────
BF_ADMIN_LOGIN_MAX=5
BF_ADMIN_LOGIN_DECAY=900
BF_ADMIN_LOGIN_LOCK=1800
BF_ADMIN_OTP_MAX=3
BF_ADMIN_OTP_DECAY=300
BF_ADMIN_OTP_LOCK=900
BF_OTP_SEND_PHONE_MAX=5
BF_OTP_SEND_IP_MAX=3
BF_CITIZEN_OTP_MAX=5
BF_CITIZEN_OTP_DECAY=600

# ─── Sécurité — HSTS ─────────────────────────────────────────────────────────
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true

# ─── Logs ────────────────────────────────────────────────────────────────────
SECURITY_LOG_CHANNEL=security
LOG_SECURITY_DAYS=90
LOG_AUDIT_DAYS=365

# ─── Next.js Citizen (.env.citizen.production) ───────────────────────────────
# NEXT_PUBLIC_API_URL=https://api.esonoya.gov.gn

# ─── Next.js Admin (.env.admin.production) ───────────────────────────────────
# NEXT_PUBLIC_API_URL=https://api.esonoya.gov.gn
