APP_NAME=eSonoya
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Africa/Conakry

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Base de données PostgreSQL ───────────────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=esonoya
DB_USERNAME=postgres
DB_PASSWORD=

# ─── Session & Cache ──────────────────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=localhost

CACHE_STORE=redis

# ─── Queue ────────────────────────────────────────────────────
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

# ─── Redis ────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ─── Mail ─────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@esonoya.gov.gn"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Sanctum (CORS stateful) ──────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost:3000,localhost:3001,127.0.0.1:3000,127.0.0.1:3001

# ─── CORS ─────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# ─── SMS Provider ─────────────────────────────────────────────
# Valeurs : interactgroup | orange | log
SMS_PROVIDER=interactgroup
SMS_SENDER_ID=eSonoya
SMS_RETRY_ATTEMPTS=3

# Provider InteractGroup
SMS_INTERACTGROUP_URL=http://sms.interactgroup.net/index.php
SMS_USERNAME=
SMS_TOKEN=

# Provider Orange (legacy)
SMS_API_KEY=
SMS_API_SECRET=
SMS_API_URL=

# ─── OTP ──────────────────────────────────────────────────────
OTP_LENGTH=6
OTP_EXPIRES_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RATE_LIMIT_MINUTES=1

# ─── QR Code ──────────────────────────────────────────────────
QR_SECRET_KEY=change_this_to_a_long_random_secret_min_32_chars

# ─── Rappels RDV ──────────────────────────────────────────────
REMINDER_HOURS_BEFORE=24

# ─── Sécurité — Sanctum ───────────────────────────────────────
SANCTUM_EXPIRATION=10080
TOKEN_CITIZEN_DAYS=7
TOKEN_ADMIN_HOURS=8

# ─── Sécurité — Mots de passe admin ──────────────────────────
PASSWORD_MIN_LENGTH=12
PASSWORD_REQUIRE_UPPER=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=true

# ─── Sécurité — Brute-force admin login ──────────────────────
BF_ADMIN_LOGIN_MAX=5
BF_ADMIN_LOGIN_DECAY=900
BF_ADMIN_LOGIN_LOCK=1800
BF_ADMIN_OTP_MAX=3
BF_ADMIN_OTP_DECAY=300
BF_ADMIN_OTP_LOCK=900

# ─── Sécurité — OTP citoyen ───────────────────────────────────
BF_OTP_SEND_PHONE_MAX=5
BF_OTP_SEND_IP_MAX=3
BF_CITIZEN_OTP_MAX=5
BF_CITIZEN_OTP_DECAY=600

# ─── Sécurité — HSTS ─────────────────────────────────────────
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true

# ─── Sécurité — Logs ─────────────────────────────────────────
SECURITY_LOG_CHANNEL=security
LOG_SECURITY_DAYS=90
LOG_AUDIT_DAYS=365

VITE_APP_NAME="${APP_NAME}"
